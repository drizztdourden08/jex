{
  "name": "@jex/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A local Electron desktop app to mirror, filter, randomize, and AI-query your Steam library.",
  "author": {
    "name": "drizztdourden08",
    "email": "drizztdourden08@users.noreply.github.com"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "stage-assets": "node scripts/build/stage-assets.mjs",
    "dev": "pnpm run stage-assets && electron-vite dev",
    "dev:nofocus": "pnpm run stage-assets && cross-env NO_FOCUS=1 electron-vite dev",
    "build": "pnpm run stage-assets && electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.app.json --noEmit",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/renderer/src/ui/**/*.css\" --allow-empty-input",
    "check:structure": "node scripts/checks/structure.mjs",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run lint:css && pnpm run check:structure",
    "verify": "pnpm run check && pnpm run build",
    "package:win": "pnpm run stage-assets && electron-vite build && electron-builder --win --publish never && node scripts/build/clean-release.mjs"
  },
  "dependencies": {
    "@jex/ai-contract": "workspace:*",
    "@jex/shared": "workspace:*",
    "@node-steam/vdf": "^2.2.0",
    "dompurify": "^3.4.11",
    "electron-store": "^10.1.0",
    "extract-zip": "^2.0.1",
    "hls.js": "^1.6.16",
    "howlongtobeat": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sql.js": "^1.14.1",
    "winreg": "^1.2.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.jex.app",
    "productName": "Jex",
    "publish": [
      {
        "provider": "github",
        "owner": "drizztdourden08",
        "repo": "jex"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "portable": {
      "artifactName": "jex-windows-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "artifactName": "jex-windows-setup.exe"
    },
    "asarUnpack": [
      "**/node_modules/sql.js/dist/sql-wasm.wasm"
    ]
  }
}
