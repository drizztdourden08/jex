# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
*.tsbuildinfo

# Local env / secrets — never commit API keys
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
*.local
.vscode/*
!.vscode/extensions.json
.idea/

# Logs
*.log
npm-debug.log*

# Optional: local Steam data snapshots a user might export
/data-export/

# AI eval harness — temporary, machine-specific (needs a downloaded model). Not committed.
/ai-eval/
/test-results/
/playwright-report/
/.playwright/

# Electron-vite build output (regenerated by `npm run build`)
out/

# Build-time asset staging (populated from assets/ by scripts/build/stage-assets.mjs).
# Brand assets are tracked under apps/desktop/assets/ — these are ephemeral copies.
/apps/desktop/build/
/apps/desktop/src/renderer/public/

# electron-builder packaging output
/apps/desktop/release/

# Built AI plugins + their assembly work dirs (regenerated by plugins/build-plugins.mjs)
/plugins/dist/
/plugins/.work/
/plugins/.signing-key.json

# Claude config — managed in the private claude-config repo, never committed here
.claude/
CLAUDE.md
